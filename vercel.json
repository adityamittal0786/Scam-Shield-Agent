{
  "buildCommand": "cd artifacts/scamshield && pnpm install --no-frozen-lockfile && pnpm run build",
  "outputDirectory": "artifacts/scamshield/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
